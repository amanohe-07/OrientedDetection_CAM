{
  "name": "oriented-detection-cam-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5190 --strictPort --configLoader runner",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build --configLoader runner",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "axios": "^1.10.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.10.4",
    "pinia": "^3.0.3",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "~5.8.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.0.5",
    "vue-tsc": "^3.0.3"
  }
}
